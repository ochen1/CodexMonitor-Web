PORT=3000

# CodexMonitor daemon integration
CODEXMONITOR_UPSTREAM_REPO=https://github.com/Dimillian/CodexMonitor
CODEXMONITOR_UPSTREAM_REF=f4e31177214a2d83660a9c727be8494e90590ea6
CODEXMONITOR_VENDOR_DIR=vendor/CodexMonitor
CODEXMONITOR_DATA_DIR=data/codexmonitor
CODEXMONITOR_LISTEN_ADDR=127.0.0.1:4732
# Optional. If omitted, a token is generated and stored in data/codexmonitor/token.txt
CODEXMONITOR_TOKEN=

# Legacy custom web PoC path
E2B_API_KEY=
E2B_TEMPLATE=codex
SANDBOX_TIMEOUT_MS=3600000
WORKSPACE_DIR=/home/user/workspace
SESSION_BUFFER_LIMIT=200000
CODEX_AUTH_SOURCE_PATH=
CODEX_START_COMMAND=codex -m gpt-5.3-codex --dangerously-bypass-approvals-and-sandbox --no-alt-screen --cd /home/user/workspace
