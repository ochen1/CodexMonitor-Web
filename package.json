{
  "name": "codex-monitor",
  "private": true,
  "version": "0.7.63",
  "type": "module",
  "scripts": {
    "sync:material-icons": "bun scripts/sync-material-icons.mjs",
    "postinstall": "bun run sync:material-icons",
    "predev": "bun run sync:material-icons",
    "dev": "vite",
    "embed:backend": "bun run --watch src/codexmonitor-web-backend.ts",
    "embed:dev": "vite --config vite.embed.config.ts",
    "embed:build": "vite build --config vite.embed.config.ts",
    "embed:typecheck": "tsc -p tsconfig.embed.json --noEmit",
    "codexmonitor:prepare": "bun run src/codexmonitor.ts prepare",
    "codexmonitor:build": "bun run src/codexmonitor.ts build",
    "codexmonitor:daemon:start": "bun run src/codexmonitor.ts daemon:start",
    "codexmonitor:daemon:status": "bun run src/codexmonitor.ts daemon:status",
    "codexmonitor:daemon:stop": "bun run src/codexmonitor.ts daemon:stop",
    "codexmonitor:workspace:add": "bun run src/codexmonitor.ts workspace:add",
    "codexmonitor:workspace:list": "bun run src/codexmonitor.ts workspace:list",
    "codexmonitor:ping": "bun run src/codexmonitor.ts ping",
    "codexmonitor:token": "bun run src/codexmonitor.ts token",
    "prebuild": "bun run sync:material-icons",
    "build": "tsc && vite build",
    "build:appimage": "NO_STRIP=1 tauri build --bundles appimage",
    "doctor": "sh scripts/doctor.sh",
    "doctor:strict": "sh scripts/doctor.sh --strict",
    "doctor:win": "bun scripts/doctor.mjs --strict",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:ds": "eslint . --ext .ts,.tsx",
    "codemod:modal-shell": "bun scripts/codemods/modal-shell-codemod.mjs",
    "codemod:panel-shell": "bun scripts/codemods/panel-shell-codemod.mjs",
    "codemod:toast-shell": "bun scripts/codemods/toast-shell-codemod.mjs",
    "codemod:ds:dry": "bun run codemod:modal-shell -- --dry-run && bun run codemod:panel-shell -- --dry-run && bun run codemod:toast-shell -- --dry-run",
    "codemod:ds": "bun run codemod:modal-shell && bun run codemod:panel-shell && bun run codemod:toast-shell",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "tauri": "tauri",
    "pretauri:dev": "bun run sync:material-icons",
    "tauri:dev": "bun run doctor:strict && tauri dev",
    "pretauri:build": "bun run sync:material-icons",
    "tauri:build": "bun run doctor:strict && tauri build",
    "pretauri:dev:win": "bun run sync:material-icons",
    "tauri:dev:win": "bun run doctor:win && tauri dev --config src-tauri/tauri.windows.conf.json",
    "pretauri:build:win": "bun run sync:material-icons",
    "tauri:build:win": "bun run doctor:win && tauri build --config src-tauri/tauri.windows.conf.json"
  },
  "dependencies": {
    "@pierre/diffs": "^1.0.6",
    "@sentry/react": "^10.36.0",
    "@tanstack/react-virtual": "^3.13.18",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "lucide-react": "^0.562.0",
    "prismjs": "^1.30.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tauri-plugin-liquid-glass-api": "^0.1.6",
    "vscode-material-icons": "^0.1.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/react": "^16.3.2",
    "@types/prismjs": "^1.26.5",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.36.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "jsdom": "^27.0.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^3.2.4"
  }
}
